# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

DATABASE_URL=postgresql://mtguser:mtgpass@localhost:5432/mtg_marketplace
SECRET_KEY=replace-this-with-a-64-character-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
SCRYFALL_BASE_URL=https://api.scryfall.com
ENVIRONMENT=development

# Payment gateways — leave blank until you have merchant accounts
TAP_SECRET_KEY=
TAP_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
